---
import Layout from '../../layouts/Layout.astro';
import Footer from './Footer.astro';
import ConverterApp from '../ConverterApp';
import { LanguageSwitcher } from '../LanguageSwitcher';
import { ThemeToggle } from '../ThemeToggle';
import { useTranslations } from '../../i18n/utils';
import { LanguageCode } from '../../i18n/constants';

export interface Props {
  lang: LanguageCode;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const title: string = `Easy to GIF | ${t('app.description')}`;
const description: string = t('app.description');
---

<Layout title={title} description={description} lang={lang}>
  <div class="site-shell-main flex min-h-full flex-col">
    <main class="site-shell-main-stage flex-1 py-8 sm:py-10">
      <div class="site-page-container flex min-h-full flex-col gap-8">
        <div class="flex flex-col gap-8">
          <div class="site-shell-hero flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
            <div class="space-y-4 text-center md:max-w-2xl md:text-left">
              <h1 class="site-shell-section-title text-4xl font-bold tracking-tight">
                {t('hero.title')}
              </h1>
              <p class="site-shell-section-subtitle text-xl md:max-w-2xl">
                {t('hero.subtitle')}
              </p>
            </div>

            <div class="self-center md:self-start md:pt-2">
              <div class="site-shell-toolbar flex flex-wrap items-center justify-center gap-3 rounded-full px-3 py-2 backdrop-blur">
                <ThemeToggle client:only="react" />
                <LanguageSwitcher client:only="react" lang={lang} />
              </div>
            </div>
          </div>
        </div>

        <!-- Converter App -->
        <ConverterApp client:only="react" lang={lang} />

        <div class="mt-auto">
          <Footer lang={lang} />
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .site-shell-main {
    position: relative;
    background:
      radial-gradient(
        circle at top right,
        color-mix(in oklch, var(--site-shell-accent) 65%, transparent) 0%,
        transparent 32rem
      ),
      linear-gradient(
        180deg,
        color-mix(in oklch, var(--site-shell-background) 88%, white) 0%,
        var(--site-shell-background) 100%
      );
    color: var(--site-shell-foreground);
  }

  .site-shell-hero {
    border: 1px solid color-mix(in oklch, var(--site-shell-border) 88%, transparent);
    border-radius: calc(var(--site-shell-radius) * 2);
    background: color-mix(in oklch, var(--site-shell-card) 86%, transparent);
    box-shadow: var(--site-shell-shadow);
    padding: clamp(1.25rem, 2vw, 1.75rem);
    backdrop-filter: blur(10px);
  }

  .site-shell-toolbar {
    border: 1px solid var(--site-shell-border);
    background: color-mix(in oklch, var(--site-shell-card) 88%, transparent);
    box-shadow: var(--site-shell-shadow);
  }

  .site-shell-section-title {
    color: var(--site-shell-foreground);
  }

  .site-shell-section-subtitle {
    color: var(--site-shell-muted-foreground);
  }
</style>
