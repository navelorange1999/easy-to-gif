---
import Layout from '../../layouts/Layout.astro';
import Footer from './Footer.astro';
import ConverterApp from '../ConverterApp';
import { LanguageSwitcher } from '../LanguageSwitcher';
import { ThemeToggle } from '../ThemeToggle';
import { useTranslations } from '../../i18n/utils';
import { LanguageCode } from '../../i18n/constants';

export interface Props {
  lang: LanguageCode;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const title: string = `Easy to GIF | ${t('app.description')}`;
const description: string = t('app.description');
---

<Layout title={title} description={description} lang={lang}>
  <div class="flex min-h-full flex-col bg-background">
    <main class="flex-1 py-8 sm:py-10">
      <div class="site-page-container flex min-h-full flex-col gap-8">
        <div class="flex flex-col gap-8">
          <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
            <div class="space-y-4 text-center md:max-w-2xl md:text-left">
              <h1 class="text-4xl font-bold tracking-tight text-foreground">
                {t('hero.title')}
              </h1>
              <p class="text-xl text-muted-foreground md:max-w-2xl">
                {t('hero.subtitle')}
              </p>
            </div>

            <div class="self-center md:self-start md:pt-2">
              <div class="flex flex-wrap items-center justify-center gap-3 rounded-full border border-border/60 bg-background/80 px-3 py-2 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-background/60">
                <ThemeToggle client:only="react" />
                <LanguageSwitcher client:only="react" lang={lang} />
              </div>
            </div>
          </div>
        </div>

        <!-- Converter App -->
        <ConverterApp client:only="react" lang={lang} />

        <div class="mt-auto">
          <Footer lang={lang} />
        </div>
      </div>
    </main>
  </div>
</Layout>
