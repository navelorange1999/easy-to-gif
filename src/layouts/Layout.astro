---
import { LanguageCode, CODE_TO_I18N_MAP, LANGUAGES } from '../i18n/constants';
import { useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: LanguageCode;
}

const { title, description, lang } = Astro.props;
const currentLang = CODE_TO_I18N_MAP[lang] || CODE_TO_I18N_MAP['en'];
const t = useTranslations(lang);
const keywords = t('app.keywords');
const siteName = t('app.title');
const repoUrl = `https://github.com/${import.meta.env.PUBLIC_GITHUB_OWNER || 'navelorange1999'}/easy-to-gif`;
const siteUrl = Astro.site ?? new URL('https://easy2gif.chankay.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogLocale = currentLang.replace('-', '_');
const alternateLinks = LANGUAGES.map((language) => ({
	href: new URL(language.path, siteUrl).toString(),
	hrefLang: language.i18nCode,
}));
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta
      name="robots"
      content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"
    />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hrefLang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl).toString()} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Easy to GIF" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url" content={canonicalUrl} />
    
    <!-- Security Headers for SharedArrayBuffer -->
    <meta http-equiv="Cross-Origin-Embedder-Policy" content="require-corp" />
    <meta http-equiv="Cross-Origin-Opener-Policy" content="same-origin" />
    
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4138695723004114"
     crossorigin="anonymous"></script>

    <!-- Theme Script -->
    <script>
      const theme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body>
    <chankay-site-shell
      position="header"
      site-name={siteName}
      repo-url={repoUrl}
    ></chankay-site-shell>
    <div class="site-page-slot">
      <slot />
    </div>
    <chankay-site-shell position="footer"></chankay-site-shell>
    <script>
      import "@chankay/site-shell/register";
    </script>
  </body>
</html>

<style is:global>
  @import '../index.css';

  html,
  body {
    min-height: 100%;
  }

  body {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  body > chankay-site-shell {
    display: block;
  }

  .site-page-slot {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .site-page-container {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }
</style>
